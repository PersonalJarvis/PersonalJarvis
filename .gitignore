logs/

# Stray screenshots & test artefacts (UI captures, GitHub shots, debug frames,
# Browser-MCP screenshots, smoke-test backend logs). Root-level images are
# throwaway scratch and must never be committed. Load-bearing images live under
# jarvis/ui/web/frontend/public, jarvis/ui/web/dist, assets/icons, the mascot
# art, and OS-Level/.../mascot-fallback.png — never at the repo root.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp
/*.mp4
/*.mov
/*.log
# OS screenshot dumps anywhere in the tree (Windows / macOS naming).
Screenshot *.png
Bildschirmfoto *.png
Screen Shot *.png

# Canonical home for development/verification screenshots (see CLAUDE.md).
# The app's boot sweep consolidates stray root captures here and auto-prunes
# them after 10 days (jarvis/core/screenshots.py). Folder is created on boot.
/screenshots/

# Sub-Agent-Sandbox-Outputs (Research-/Demo-Drops, kein Projekt-Code)
examples/
github-research/
# Phase-6 worker-isolation parent (worktrees + per-mission OpenClaw state).
# Each mission gets a fresh `git worktree` under here; never commit.
sub-agents-outputs/

# Generated test inventory (refreshed by tooling, never reviewed by hand).
all-tests.list

# Wiki auto-backups (rolling tarballs from the backup scheduler; never reviewed).
wiki/wiki-backups/

# Excalidraw export scratch + diagram-capture screenshots under scripts/.
scripts/_*.png
scripts/_*.json
scripts/_flow_in_browser.png

