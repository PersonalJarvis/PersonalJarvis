!.claude/agents/
!.claude/commands/
!.claude/skills/
.playwright-mcp/

# TypeScript incremental build cache (regenerated on every `tsc --build`)
*.tsbuildinfo

# Standalone sibling project — versioned in its own repo
jarvis-promo-video/

# Obsidian transient workspace state (plugin configs ARE committed)
wiki/obsidian-vault/.obsidian/workspace.json
wiki/obsidian-vault/.obsidian/workspace-mobile.json
wiki/obsidian-vault/.obsidian/workspaces.json
wiki/obsidian-vault/.trash/

# Generated worktree inventory (ephemeral)
git-worktree-status.csv

# ============================================================
# Open-source separation (Wave 0, 2026-05-30): personal state stays
# local, only shared code + an empty seed scaffold ship. The files below
# were `git rm --cached`-ed (kept on disk, removed from tracking). See
# Downloads/Open-Source-Privacy-Separation.md for the full plan.
# ============================================================

# Personal config instance — ship jarvis.toml.example instead. Jarvis already
# boots with NO jarvis.toml (pure Pydantic defaults, core/config.py).
/jarvis.toml
# Per-user MCP server config — ship mcp.json.example instead.
/mcp.json

# Personal knowledge-vault CONTENT. The vault self-creates on first run
# (jarvis/memory/wiki/integration.py seeds schema.md); only the empty skeleton
# (schema.md, README.md, 00-index/, 99-templates/) ships as a seed.
wiki/obsidian-vault/sessions/
wiki/obsidian-vault/_archive/
wiki/obsidian-vault/entities/
wiki/obsidian-vault/concepts/
wiki/obsidian-vault/projects/
wiki/obsidian-vault/log.md
# Personal Obsidian UI state (theme + plugin-config defaults stay tracked as a seed).
wiki/obsidian-vault/.obsidian/graph.json
wiki/obsidian-vault/.obsidian/hotkeys.json

# Dev scratch & personal incident reports (pytest dumps, recovery notes).
/_*.txt
/claude-progress.txt
/macicon-candidates.json
/RECOVERY.md
/recovery-report.md
/restore-report.md
# One-off scratch experiments at the repo root (cookie-transplant utilities,
# promo-video brand drops, ad-hoc probes). Anything named `scratch_*` /
# `scratch/` is personal throwaway work and must never be committed.
/scratch_*
/scratch/

# Misc per-user state the code may write into the repo tree.
state/

# TypeScript incremental build cache — regenerated every build
*.tsbuildinfo
