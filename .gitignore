# Secrets (nie committen — Secrets liegen im Windows Credential Manager)
.env
.env.local
.env.*.local
# Local plaintext API-key snapshot — developer convenience file, must stay local
apikeys-snapshot.md
*.pem
# Exception: supply-chain PUBLIC keys live in install/keys/ and MUST be
# committed plain so the verifier can pin them. Encrypted *.enc private
# keys are also committed (passphrase lives in GH Actions secrets / pw mgr).
!install/keys/*.pub.pem
!install/keys/*.pub
!install/keys/*.enc

# Config-Drift-Guard temp backups (never commit)
jarvis.toml.tmp
*.toml.tmp
*.key
secrets/
credentials/
service-account*.json

