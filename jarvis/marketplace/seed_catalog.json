{
  "version": 1,
  "schema_version": "2026-05-09",
  "plugins": [
    {
      "id": "github",
      "display_name": "GitHub",
      "description": "Repos, issues, pull requests and Actions runs",
      "category": "Developer",
      "logo_slug": "github",
      "logo_color": "F4F4F5",
      "featured": true,
      "auth": {
        "mode": "pat_paste",
        "token_creation_url": "https://github.com/settings/tokens/new?scopes=repo,workflow,read:user&description=Personal+Jarvis",
        "token_prefix": "ghp",
        "validation_endpoint": "https://api.github.com/user",
        "instruction_md": "1. The link below opens GitHub with the right scopes (repo, workflow, read:user) already ticked.\n2. Pick an expiration (90 days is a sensible default), then click 'Generate token'.\n3. Copy the token (shown only once) and paste it below.\n4. If your repos sit behind SAML SSO, click 'Configure SSO' next to the new token after creation."
      },
      "mcp_server": {
        "transport": "stdio",
        "install": [
          "docker", "run", "-i", "--rm",
          "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
          "ghcr.io/github/github-mcp-server"
        ],
        "env_template": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "$plugin_github_access_token"
        }
      },
      "post_install_hint_md": "If you use SAML SSO, you may need to authorize this token at https://github.com/settings/tokens after install."
    },
    {
      "id": "vercel",
      "display_name": "Vercel",
      "description": "Deployments, runtime logs, domains and env-vars",
      "category": "Developer",
      "logo_slug": "vercel",
      "logo_color": "F4F4F5",
      "featured": true,
      "auth": {
        "mode": "pat_paste",
        "token_creation_url": "https://vercel.com/account/tokens",
        "token_prefix": "vcp",
        "validation_endpoint": "https://api.vercel.com/v2/user",
        "instruction_md": "1. Click 'Create Token'\n2. Name: 'Personal Jarvis'\n3. Choose 'Full Account' or a specific team\n4. Copy the token (shown once)\n5. Paste below"
      },
      "mcp_server": {
        "transport": "rest_wrapper",
        "rest_base_url": "https://api.vercel.com",
        "auth_header_template": "Authorization: Bearer ${plugin_vercel_access_token}",
        "tool_set": "vercel_rest_minimal"
      },
      "future_v2_note": "Apply for mcp.vercel.com client-allowlist; switch mode to hosted_mcp_allowlist when approved."
    },
    {
      "id": "supabase",
      "display_name": "Supabase",
      "description": "Projects, SQL, Edge Functions, advisors and logs",
      "category": "Developer",
      "logo_slug": "supabase",
      "featured": false,
      "auth": {
        "mode": "pat_paste",
        "token_creation_url": "https://supabase.com/dashboard/account/tokens",
        "token_prefix": "sbp",
        "validation_endpoint": "https://api.supabase.com/v1/projects",
        "instruction_md": "1. Click 'Generate new token'\n2. Name: 'Personal Jarvis'\n3. Copy the token (shown once)"
      },
      "mcp_server": {
        "transport": "stdio",
        "install": [
          "npx", "-y", "@supabase/mcp-server-supabase@latest",
          "--read-only",
          "--access-token", "$plugin_supabase_access_token"
        ],
        "env_template": {}
      },
      "post_install_hint_md": "Read-only mode is enabled by default. To allow write operations, toggle in Plugin settings."
    },
    {
      "id": "notion",
      "display_name": "Notion",
      "description": "Pages, databases and comments — multi-workspace",
      "category": "Productivity",
      "logo_slug": "notion",
      "logo_color": "F4F4F5",
      "featured": true,
      "auth": {
        "mode": "hosted_mcp_oauth_dcr",
        "discovery_url": "https://mcp.notion.com/.well-known/oauth-protected-resource",
        "mcp_url": "https://mcp.notion.com/mcp",
        "fallback_mcp_url": "https://mcp.notion.com/sse",
        "access_token_ttl_seconds": 3600,
        "refresh_supported": true,
        "capabilities": [
          "read_content",
          "update_content",
          "insert_content",
          "read_comments",
          "insert_comments",
          "user_information_with_email"
        ]
      },
      "mcp_server": {
        "transport": "http",
        "url": "https://mcp.notion.com/mcp",
        "auth_header_template": "Authorization: Bearer ${plugin_notion_access_token}"
      }
    },
    {
      "id": "slack",
      "display_name": "Slack",
      "description": "Channels, DMs, search and Canvas drafts",
      "category": "Communication",
      "logo_slug": "slack",
      "logo_url": "/plugin-assets/slack-logo.svg",
      "featured": true,
      "auth": {
        "mode": "oauth_pkce_loopback",
        "authorization_url": "https://slack.com/oauth/v2/authorize",
        "token_url": "https://slack.com/api/oauth.v2.access",
        "revocation_url": "https://slack.com/api/auth.revoke",
        "client_id": "REPLACE_WITH_JARVIS_SLACK_APP_CLIENT_ID",
        "callback_port": 3118,
        "scopes": [
          "chat:write",
          "users:read",
          "users:read.email",
          "search:read.public",
          "search:read.private",
          "search:read.im",
          "search:read.mpim",
          "channels:history",
          "groups:history",
          "im:history",
          "mpim:history"
        ],
        "user_scopes_only": true,
        "refresh_supported": true,
        "refresh_token_ttl_days": 30
      },
      "mcp_server": {
        "transport": "http",
        "url": "https://mcp.slack.com/mcp",
        "auth_header_template": "Authorization: Bearer ${plugin_slack_access_token}"
      },
      "post_install_hint_md": "Slack PKCE apps use user-level scopes only — Jarvis acts as you, not as a bot. If your workspace admin requires approval, the OAuth flow will surface that prompt automatically."
    },
    {
      "id": "linear",
      "display_name": "Linear",
      "description": "Issues, projects, cycles and roadmap for software teams",
      "category": "Developer",
      "logo_slug": "linear",
      "logo_color": "F4F4F5",
      "featured": true,
      "auth": {
        "mode": "hosted_mcp_oauth_dcr",
        "discovery_url": "https://mcp.linear.app/.well-known/oauth-protected-resource",
        "mcp_url": "https://mcp.linear.app/mcp",
        "refresh_supported": true
      },
      "mcp_server": {
        "transport": "http",
        "url": "https://mcp.linear.app/mcp",
        "auth_header_template": "Authorization: Bearer ${plugin_linear_access_token}"
      }
    }
  ]
}
