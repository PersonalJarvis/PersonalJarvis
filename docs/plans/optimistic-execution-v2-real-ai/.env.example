# Optimistic Execution v2 — LLM provider configuration (hardware-agnostic).
# Copy to `.env` and edit. The worker speaks the OpenAI-compatible Chat API,
# so ANY provider exposing /v1/chat/completions works — local OR cloud — and the
# whole system is configured here, never in code (no hardcoded GPU/OS/provider).
#
# LLM_BACKEND: "http" (real OpenAI-compatible call) or "mock" (deterministic,
#              no network; what the test-suite uses).
LLM_BACKEND=http

# --- DEFAULT: local Ollama (free, no key, runs on your machine) ---------------
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=

# --- Cloud alternatives (comment the Ollama block above, uncomment one here) --
# Groq (fast, OpenAI-compatible):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...
#
# OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5.5
# LLM_API_KEY=sk-...
#
# OpenRouter (100+ models behind one key):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemini-3.1-pro-preview
# LLM_API_KEY=sk-or-...
#
# Google Gemini (OpenAI-compatible endpoint):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-3.5-flash
# LLM_API_KEY=...
#
# LM Studio (local desktop app):
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=your-local-model
# LLM_API_KEY=

# --- Tuning -------------------------------------------------------------------
LLM_TIMEOUT=120
LLM_SYSTEM_PROMPT=You are the background worker of a voice assistant. Answer concisely and helpfully, in the user's language.

# --- Server -------------------------------------------------------------------
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8008
