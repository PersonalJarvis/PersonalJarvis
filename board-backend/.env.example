# Kopiere nach .env und fuelle aus. .env ist via .gitignore ausgeschlossen.

# Pflicht: Admin-Token. NUR fuer /api/v1/identity/register.
# Empfohlen: 32+ random bytes hex.
JARVIS_BOARD_ADMIN_TOKEN=

# Optional: Host-Port (Default 8765)
JARVIS_BOARD_HOST_PORT=8765

# Optional: Rate-Limit-Schwellwert (Default 10 Requests/min/IP)
JARVIS_BOARD_RATE_LIMIT=10

# Optional: Replay-Window in Sekunden (Default 300 = 5 min)
JARVIS_BOARD_REPLAY_WINDOW=300
