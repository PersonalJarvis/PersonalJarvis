{
  "name": "infographic_create",
  "description": "Generate infographic. Requires confirm=True after user approval.\n\nArgs:\n    notebook_id: Notebook UUID\n    source_ids: Source IDs (default: all)\n    orientation: landscape|portrait|square\n    detail_level: concise|standard|detailed\n    language: BCP-47 code (en, es, fr, de, ja)\n    focus_prompt: Optional focus text\n    confirm: Must be True after user approval",
  "inputSchema": {
    "properties": {
      "notebook_id": {
        "title": "Notebook Id",
        "type": "string"
      },
      "source_ids": {
        "anyOf": [
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Source Ids"
      },
      "orientation": {
        "default": "landscape",
        "title": "Orientation",
        "type": "string"
      },
      "detail_level": {
        "default": "standard",
        "title": "Detail Level",
        "type": "string"
      },
      "language": {
        "default": "en",
        "title": "Language",
        "type": "string"
      },
      "focus_prompt": {
        "default": "",
        "title": "Focus Prompt",
        "type": "string"
      },
      "confirm": {
        "default": false,
        "title": "Confirm",
        "type": "boolean"
      }
    },
    "required": [
      "notebook_id"
    ],
    "type": "object"
  }
}