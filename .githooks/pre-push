#!/bin/sh
# pre-push: versioned local mirror of the credential + language CI gates.
#
# Direct pushes to the public repo are the NORMAL flow (CLAUDE.md rule 2,
# standard shared-history workflow since 2026-07-18). What stays fail-closed
# is credential protection, never a raw-push block.
#
#   1. CREDENTIAL gate (FAIL-CLOSED on positive findings) — scripts/ci/privacy_pre_push.py
#        (A) logs a heads-up when the target is the public repo (never blocks);
#        (B) blocks a commit carrying a private maintainer email (author/committer);
#        (C) blocks a real secret / forbidden secret file in the pushed files.
#      The gate itself fails OPEN only when it genuinely cannot run (no python,
#      scanner import fails, diff range unknown) — layer-3 CI is the backstop.
#
#   2. LANGUAGE gate (FAIL-OPEN) — scripts/ci/check_no_new_german.py
#        aborts only on a CONFIRMED newly-added German hit (Output Language Policy).
#
# This hook is VERSIONED in .githooks/; the orchestrator wires it via
# `git config core.hooksPath .githooks` (this hook never sets that itself).
#
# Bypass once:  git push --no-verify
#
# git passes the remote name as $1 and the remote URL as $2; the pushed refs
# arrive on stdin, one line per ref:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>

remote_name="$1"
remote_url="$2"

# Prefer the repository venv because several gates import the project's dev
# dependencies. Cover POSIX and Windows layouts, then retain the historical
# known-good Windows interpreter before falling back to PATH. No Python at all
# -> fail OPEN.
PY=".venv/bin/python3"
[ -x "$PY" ] || PY=".venv/bin/python"
[ -x "$PY" ] || PY=".venv/Scripts/python.exe"
[ -x "$PY" ] || PY="/c/Program Files/Python311/python.exe"
[ -x "$PY" ] || PY="$(command -v python3 2>/dev/null || command -v python 2>/dev/null)"
[ -n "$PY" ] || exit 0

# Read all pushed refs from stdin FIRST (into a temp file), so each gate's own
# subprocess can never consume the hook's stdin pipe and corrupt the loop.
refs_file="$(mktemp 2>/dev/null || echo "${TMPDIR:-/tmp}/prepush_refs.$$")"
cat > "$refs_file"

status=0
privacy_hit=0
language_hit=0

# --- 1) PRIVACY gate (FAIL-CLOSED) --------------------------------------------
# Feed the buffered refs to the privacy gate on stdin; it reads remote name/url
# from argv. A non-zero exit means a CONFIRMED privacy block.
privacy_gate="scripts/ci/privacy_pre_push.py"
if [ -f "$privacy_gate" ]; then
    "$PY" "$privacy_gate" "$remote_name" "$remote_url" < "$refs_file"
    if [ "$?" -ne 0 ]; then
        status=1
        privacy_hit=1
    fi
fi

# --- 2) LANGUAGE gate (FAIL-OPEN) ---------------------------------------------
# rc == 1 means confirmed newly-added German; any other rc is fail-open.
language_gate="scripts/ci/check_no_new_german.py"
if [ -f "$language_gate" ]; then
    while read -r local_ref local_sha remote_ref remote_sha; do
        # Skip branch deletions (local_sha all zeros).
        case "$local_sha" in *[!0]*) : ;; *) continue ;; esac

        # Diff base = what the remote already has; new branch -> main.
        case "$remote_sha" in
            *[!0]*) base="$remote_sha" ;;
            *)      base="origin/main" ;;
        esac

        # </dev/null keeps the gate from touching the hook's stdin; rc captured.
        "$PY" "$language_gate" "$base" </dev/null
        rc=$?
        if [ "$rc" -eq 1 ]; then
            status=1
            language_hit=1
        fi
    done < "$refs_file"
fi

# --- 3) CLI COVERAGE gate (FAIL-CLOSED) ---------------------------------------
# Every jarvis/ui/web/*_routes.py router must be mounted in server.py, so every
# WebUI action stays reachable from the `jarvis` CLI (catches the unmounted-router
# / dead-command bug class). Static + stdlib-only; safe to run on every push.
cli_gate="scripts/ci/check_cli_coverage.py"
if [ -f "$cli_gate" ]; then
    "$PY" "$cli_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        cli_coverage_hit=1
    fi
fi

# --- 3b) DANGER METADATA gate (FAIL-CLOSED) ------------------------------------
# A mutating route whose path matches a destructive marker (/restart, /kill,
# /outbound, ...) must declare openapi_extra x-jarvis-dangerous, so the CLI's
# dynamic layer and the Command Registry demand an explicit --yes/confirmation.
# Static + stdlib-only; safe to run on every push.
danger_gate="scripts/ci/check_danger_metadata.py"
if [ -f "$danger_gate" ]; then
    "$PY" "$danger_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        danger_meta_hit=1
    fi
fi

# --- 4) CLI DOCGEN drift gate (FAIL-CLOSED) -----------------------------------
# docs/jarvis-cli-reference.md is generated from the curated command tree; this
# fails the push if a command was added/changed without regenerating it. Static
# (imports the Typer app only, no live server). Run
# `python scripts/ci/gen_cli_reference.py` to fix a drift.
docgen_gate="scripts/ci/gen_cli_reference.py"
if [ -f "$docgen_gate" ]; then
    "$PY" "$docgen_gate" --check </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        docgen_hit=1
    fi
fi

# --- 4b) COMMANDS DOCGEN drift gate (FAIL-CLOSED) -------------------------------
# docs/commands-reference.md is generated from the Command Registry; this fails
# the push if a registry command was added/changed without regenerating it.
# Run `python scripts/ci/gen_commands_reference.py` to fix a drift.
cmddocs_gate="scripts/ci/gen_commands_reference.py"
if [ -f "$cmddocs_gate" ]; then
    "$PY" "$cmddocs_gate" --check </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        cmddocs_hit=1
    fi
fi

# --- 5) DOCS PRIVACY gate (FAIL-CLOSED) ---------------------------------------
# Personal data must never leave the machine inside a documentation file:
# the maintainer's real name, private email/handle, personal Windows paths,
# machine/account ids. This is the docs-content half the privacy_pre_push gate
# above does NOT cover (it checks commit author emails + real secrets, not the
# name/path text inside docs/). Same canonical manifest the public-release
# scrub uses (scripts/ci/privacy_gate/references/pii-scrub.tsv), so the two
# never drift. Read-only scan over tracked docs/; exit 1 on any hit.
docs_privacy_gate="scripts/ci/docs_privacy_scan.py"
if [ -f "$docs_privacy_gate" ]; then
    "$PY" "$docs_privacy_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        docs_privacy_hit=1
    fi
fi

# --- 5a) PUBLIC DOCS contract (FAIL-CLOSED) ----------------------------------
# Reader-facing pages must stay complete, cross-linked, short-exampled, and
# free of secret/PII shapes even when the wider engineering archive changes.
public_docs_gate="scripts/ci/check_public_docs.py"
if [ -f "$public_docs_gate" ]; then
    "$PY" "$public_docs_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        public_docs_hit=1
    fi
fi

# --- 5b) PRIVATE-KEY gate (FAIL-CLOSED) ---------------------------------------
# Signing private keys (and the retired signing passphrase) must NEVER enter the
# repo — they live ONLY in GitHub Actions secrets (WAVE2_OFFLINE_KEY_B64 /
# WAVE4_MLDSA65_KEY_B64). Blocks a full PEM PRIVATE KEY block, a tracked
# *.key/*.key.enc file, or a WAVE2_CEREMONY_PASSPHRASE=<value> line. The demo
# passphrase once leaked into 14 public snapshots; this guards that class.
# Public keys are fine. Stdlib + git only, so it runs anywhere the hook does.
privkey_gate="scripts/ci/check_no_private_keys.py"
if [ -f "$privkey_gate" ]; then
    "$PY" "$privkey_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        privkey_hit=1
    fi
fi

# --- 5c) DIST CONSISTENCY gate (FAIL-CLOSED on a confirmed broken bundle) ------
# The shipped frontend bundle must be self-consistent IN GIT: dist/index.html
# and every chunk reachable from it (dynamic imports included) must resolve to
# tracked files, or every fresh clone boots to a blank spinner while the
# builder's machine looks fine (cloud review 2026-07-18, AP-23). Checks HEAD,
# so it also catches breakage a parallel session committed. rc 1 = confirmed
# missing chunk; any other rc fails OPEN. Stdlib + git only, sub-second.
dist_gate="scripts/ci/check_dist_consistency.py"
if [ -f "$dist_gate" ]; then
    "$PY" "$dist_gate" </dev/null
    if [ "$?" -eq 1 ]; then
        status=1
        dist_hit=1
    fi
fi

# --- 6) REQUIREMENTS SYNC gate (FAIL-CLOSED) ----------------------------------
# requirements.in (source for the hash-pinned requirements.txt lockfile) must
# mirror pyproject.toml [project].dependencies exactly. When they drift, an
# extras-only, torch-pulling package (silero-vad, sentence-transformers, …) can
# leak into the base lockfile, baking the multi-GB GPU CUDA wheel stack into the
# installer and bricking `pip install --require-hashes -r requirements.txt` for
# every non-maintainer machine (nvidia-cufile unresolvable on plain PyPI). This
# is the guard for that "works on my machine" class (AP-23). The script itself
# fails OPEN when `packaging` is unavailable; CI is the backstop.
reqsync_gate="scripts/ci/check_requirements_sync.py"
if [ -f "$reqsync_gate" ]; then
    "$PY" "$reqsync_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        reqsync_hit=1
    fi
fi

# --- 6b) LOCKFILE UNIVERSAL + GPU-FREE gate (FAIL-CLOSED) ----------------------
# Companion to the sync gate above: inspects the compiled requirements.txt itself
# and blocks a lockfile that was regenerated the wrong way — one missing the
# `uv pip compile --universal` marker (pins a single OS) or one that re-baked the
# maintainer's nvidia-*/torch/CUDA wheels into the base file every downloader
# installs (AP-23). Stdlib only, so it runs anywhere the hook does.
lockfile_gate="scripts/ci/check_lockfile_universal.py"
if [ -f "$lockfile_gate" ]; then
    "$PY" "$lockfile_gate" </dev/null
    if [ "$?" -ne 0 ]; then
        status=1
        lockfile_hit=1
    fi
fi

# --- 7) BOOT BUDGET gate (FAIL-CLOSED on a measured overrun) --------------------
# A feature that sneaks heavy work onto the startup critical path must fail the
# push, not the user's day (TTU forensic 2026-07-02: a wake-model change put a
# 114.7 s load cascade on boot unnoticed). Runs ONE isolated cold boot via the
# committed harness and enforces the budgets: window <= 8 s, voice-usable and
# app-interactive <= 20 s each (~4x the measured medians, so machine variance
# never flakes while every real regression class blows through). Exit 78 =
# "could not measure" (no interpreter/harness) -> fail OPEN; a headless host
# checks the window anchor only. Costs ~30-60 s per push — pushes are rare and
# deliberate in this repo. Skip once with JARVIS_SKIP_BOOT_BUDGET=1.
boot_budget_gate="scripts/ci/check_boot_budget.py"
if [ -f "$boot_budget_gate" ] && [ "${JARVIS_SKIP_BOOT_BUDGET:-0}" != "1" ]; then
    echo "pre-push: boot-budget gate — measuring one isolated cold boot (~30-60 s) ..."
    "$PY" "$boot_budget_gate" </dev/null
    rc=$?
    if [ "$rc" -ne 0 ] && [ "$rc" -ne 78 ]; then
        status=1
        boot_budget_hit=1
    fi
fi

rm -f "$refs_file"

if [ "$status" -ne 0 ]; then
    echo ""
    if [ "$privacy_hit" -ne 0 ]; then
        echo "pre-push BLOCKED: CREDENTIAL gate (private email / secret in pushed files)."
        echo "  See the findings above. Remove the credential from the commit, then retry."
    fi
    if [ "$language_hit" -ne 0 ]; then
        echo "pre-push BLOCKED: LANGUAGE gate (newly added German text)."
    fi
    if [ "${cli_coverage_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: CLI COVERAGE gate (a route module is not mounted)."
        echo "  Mount it in jarvis/ui/web/server.py — see the findings above."
    fi
    if [ "${danger_meta_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: DANGER METADATA gate (destructive route without x-jarvis-dangerous)."
        echo "  Add openapi_extra={\"x-jarvis-dangerous\": True} to the route decorator."
    fi
    if [ "${docgen_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: CLI DOCGEN drift (jarvis-cli-reference.md out of date)."
        echo "  Run: python scripts/ci/gen_cli_reference.py  and commit the result."
    fi
    if [ "${cmddocs_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: COMMANDS DOCGEN drift (commands-reference.md out of date)."
        echo "  Run: python scripts/ci/gen_commands_reference.py  and commit the result."
    fi
    if [ "${docs_privacy_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: DOCS PRIVACY gate (personal data in docs/)."
        echo "  See the findings above. Fix with:"
        echo "    python scripts/ci/docs_privacy_scan.py --fix <file>"
        echo "  or run the docs-privacy-reviewer sub-agent for a semantic pass."
    fi
    if [ "${public_docs_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: PUBLIC DOCS contract (reader guide incomplete or unsafe)."
        echo "  Run: python scripts/ci/check_public_docs.py"
    fi
    if [ "${privkey_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: PRIVATE-KEY gate (private key / passphrase in the tree)."
        echo "  Signing private keys live ONLY in GitHub Actions secrets, never in the"
        echo "  repo. Remove the key material shown above (public keys are fine)."
    fi
    if [ "${dist_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: DIST CONSISTENCY gate (half-shipped frontend bundle)."
        echo "  dist/index.html (or a chunk it loads) references files git does not"
        echo "  track — a fresh clone would boot to a blank spinner. Commit the"
        echo "  rebuilt bundle as ONE set (see the MISSING list above):"
        echo "    git add jarvis/ui/web/dist/index.html jarvis/ui/web/dist/assets/"
    fi
    if [ "${reqsync_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: REQUIREMENTS SYNC gate (requirements.in != pyproject deps)."
        echo "  See the diff above. Fix requirements.in, then regenerate the lockfile:"
        echo "    uv pip compile --universal --generate-hashes --python-version 3.11 --output-file=requirements.txt requirements.in"
    fi
    if [ "${lockfile_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: LOCKFILE gate (requirements.txt not universal or has GPU/CUDA/torch wheels)."
        echo "  See the findings above. Regenerate the platform-universal lockfile with:"
        echo "    uv pip compile --universal --generate-hashes --python-version 3.11 --output-file=requirements.txt requirements.in"
    fi
    if [ "${boot_budget_hit:-0}" -ne 0 ]; then
        echo "pre-push BLOCKED: BOOT BUDGET gate (cold-boot startup budget exceeded)."
        echo "  A change put work on the critical startup path. Move it behind"
        echo "  _heavy_backend_bg / a deferred scan (docs/diagnostics/BOOT-TTU-NOTES.md,"
        echo "  section 'How to add a feature WITHOUT slowing boot')."
        echo "  Verify locally:  python scripts/ci/check_boot_budget.py"
        echo "  Skip once:       JARVIS_SKIP_BOOT_BUDGET=1 git push"
    fi
    echo "Bypass once with:  git push --no-verify   (layer-3 CI is the backstop)."
fi
exit "$status"
