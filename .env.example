# ============================================================
#  Personal Jarvis — environment variables (template)
# ------------------------------------------------------------
#  Copy this file to `.env` and fill in your real keys, OR run the
#  setup wizard (`python -m jarvis --wizard`), which stores keys in
#  your OS credential manager instead. `.env` is NOT committed
#  (see .gitignore). NEVER put real keys in jarvis.toml or any
#  committed file.
#
#  Secret resolution order (jarvis/core/config.py:get_secret):
#    1. OS credential manager (keyring, service "personal-jarvis")
#    2. environment variable
#    3. this .env file (dev fallback only)
#
#  Every provider is OPTIONAL — set only the keys you actually use.
#  A single cloud Brain key (e.g. GEMINI_API_KEY) is enough to boot.
# ============================================================


# ---- Brain providers ------------------------------------------
# Gemini (Google AI Studio) — default Brain. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GOOGLE_AIStudio_API_KEY=
# Anthropic Claude. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI (GPT brain, Whisper STT, TTS). https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_ORG_ID=
# OpenAI Codex CLI worker (separate from the OpenAI brain key).
CODEX_OPENAI_API_KEY=
# OpenRouter — universal gateway to all models via one key. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# xAI Grok (brain + Grok Voice TTS). https://console.x.ai/
GROK_API_KEY=


# ---- Speech-to-Text (STT) -------------------------------------
# Groq Whisper — ultra-fast cloud STT (default). https://console.groq.com/keys
GROQ_API_KEY=
# Deepgram — Flux / Nova-3 with integrated end-of-turn. https://console.deepgram.com/
DEEPGRAM_API_KEY=
# OpenAI Whisper STT reuses OPENAI_API_KEY (see above).


# ---- Text-to-Speech (TTS) -------------------------------------
# Cartesia Sonic 3.5 — 42 languages incl. German. https://play.cartesia.ai/keys
CARTESIA_API_KEY=
# ElevenLabs premium TTS. https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Grok Voice TTS reuses GROK_API_KEY (see above).
# Google Cloud TTS (Neural2) — path to a service-account JSON.
GOOGLE_APPLICATION_CREDENTIALS=
# Gemini Flash TTS via Vertex AI (bypasses the AI-Studio preview RPD cap):
# set your GCP project id here; SA path is in jarvis.toml [tts].service_account_path.
JARVIS__TTS__VERTEX_PROJECT=


# ---- Web search (agent tools) ---------------------------------
# Tavily: https://app.tavily.com/home   Serper: https://serper.dev/api-key   Brave: https://api.search.brave.com/app/keys
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=


# ---- Weather --------------------------------------------------
# https://openweathermap.org/api
OPENWEATHER_API_KEY=


# ---- Channels & telephony -------------------------------------
# Telegram bot. https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Discord bot. https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Twilio — call Jarvis on a phone number. Auth token only; Account SID +
# number live in jarvis.toml [integrations.twilio]. https://console.twilio.com
TWILIO_AUTH_TOKEN=


# ---- Admin helper ---------------------------------------------
# HMAC key for Phase-5 admin ops (winget/services/registry/firewall).
# Auto-generated on first helper start — you normally do NOT set this by hand.
JARVIS_ADMIN_HMAC=


# ---- App settings ---------------------------------------------
APP_ENV=development
LOG_LEVEL=info
